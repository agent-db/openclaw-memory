{
  "name": "@agent-db/openclaw-memory",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-db/openclaw-memory.git"
  },
  "bugs": {
    "url": "https://github.com/agent-db/openclaw-memory/issues"
  },
  "version": "0.1.0",
  "description": "OpenClaw gateway plugin: long-term, cross-device agent memory backed by AgentDB (Schema.org JSON-LD entities with semantic recall).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1",
      "minGatewayVersion": "2026.7.1"
    }
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "prettier --check \"src/**/*.ts\" \"skills/**/*.md\" \"test/*.cjs\"",
    "pretest": "npm run clean && npm run build",
    "test": "node --test test/*.test.cjs",
    "prepack": "npm pkg set 'dependencies[@agent-db/client]=^1.0.0'",
    "postpack": "npm pkg set 'dependencies[@agent-db/client]=file:../agentdb'"
  },
  "keywords": [
    "openclaw",
    "clawhub",
    "memory",
    "agentdb",
    "schema.org",
    "json-ld",
    "agent"
  ],
  "author": "TurboSchema",
  "license": "MIT",
  "dependencies": {
    "@agent-db/client": "file:../agentdb"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "openclaw": "^2026.7.1-2",
    "prettier": "^3.9.5",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "sideEffects": false
}
